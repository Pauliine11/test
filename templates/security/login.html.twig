{# templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-5">

        <div class="text-center mb-4">
          <h1 class="fw-bold mb-2">Connexion</h1>
          <p class="text-body-secondary fs-5 mb-0">
            Accède à ton compte pour suivre tes commandes et favoris.
          </p>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4 p-md-5">

            {% if error %}
              <div class="alert alert-danger rounded-4" role="alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
              </div>
            {% endif %}

            {% if app.user %}
              <div class="alert alert-info rounded-4" role="alert">
                Tu es déjà connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                <a href="{{ path('app_logout') }}" class="alert-link">Se déconnecter</a>
              </div>
            {% endif %}

            <form method="post" class="vstack gap-3">
              <div>
                <label for="inputEmail" class="form-label">Email</label>
                <input
                  type="email"
                  value="{{ last_username }}"
                  name="email"
                  id="inputEmail"
                  class="form-control form-control-lg rounded-3"
                  autocomplete="email"
                  placeholder="email@exemple.com"
                  required
                  autofocus
                >
              </div>

              <div>
                <label for="inputPassword" class="form-label">Mot de passe</label>
                <input
                  type="password"
                  name="password"
                  id="inputPassword"
                  class="form-control form-control-lg rounded-3"
                  autocomplete="current-password"
                  placeholder="••••••••"
                  required
                >
              </div>

              <div class="d-flex align-items-center justify-content-between">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                  <label class="form-check-label" for="rememberMe">Se souvenir de moi</label>
                </div>

                {# Décommente si tu ajoutes un système "mot de passe oublié" #}
                {# <a class="small text-decoration-none" href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a> #}
              </div>

              <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

              <button class="btn btn-primary btn-lg w-100 rounded-3" type="submit">
                Se connecter
              </button>
            </form>

            <hr class="my-4">

            <div class="text-center">
              <span class="text-body-secondary">Pas encore de compte ?</span>
              <a href="{{ path('app_register') }}" class="text-decoration-none fw-semibold">Créer un compte</a>
            </div>
          </div>
        </div>

        <p class="text-center text-body-secondary small mt-3 mb-0">
          En cas de souci, contacte-nous via la page <a class="link-secondary" href="#">Contact</a>.
        </p>

      </div>
    </div>
  </div>
</section>
{% endblock %}
