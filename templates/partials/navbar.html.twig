<nav class="navbar-luxe sticky-top">
  <div class="container">
    <div class="navbar-luxe-inner">

      {# Logo #}
      <a class="navbar-luxe-brand" href="{{ path('app_home') }}">
        <span class="brand-mark">✦</span>
        <span>Atelier d'Art</span>
      </a>

      {# Liens desktop #}
      <ul class="navbar-luxe-nav d-none d-lg-flex">
        <li>
          <a class="navbar-luxe-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}"
             href="{{ path('app_home') }}">Accueil</a>
        </li>
        <li>
          <a class="navbar-luxe-link {% if app.request.attributes.get('_route') == 'app_shop' %}active{% endif %}"
             href="{{ path('app_shop') }}">Boutique</a>
        </li>
        <li>
          <a class="navbar-luxe-link" href="{{ path('app_shop') }}">Collections</a>
        </li>
        <li>
          <a class="navbar-luxe-link" href="#">À propos</a>
        </li>
        <li>
          <a class="navbar-luxe-link" href="#">Contact</a>
        </li>
      </ul>

      {# Actions #}
      <div class="navbar-luxe-actions">

        {# Panier #}
        <a href="#" class="navbar-luxe-cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/>
          </svg>
          <span class="navbar-luxe-cart-badge">0</span>
        </a>

        {# User #}
        {% if app.user %}
          <div class="dropdown">
            <button class="btn-gold dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false"
                    style="font-size:.72rem; padding:.6rem 1.2rem;">
              {{ app.user.userIdentifier }}
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2">
              <li><a class="dropdown-item font-body" href="#">Mon compte</a></li>
              {% if is_granted('ROLE_ADMIN') %}
                <li><a class="dropdown-item font-body" href="/admin">Administration</a></li>
              {% endif %}
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item font-body text-danger" href="{{ path('app_logout') }}">Se déconnecter</a></li>
            </ul>
          </div>
        {% else %}
          <a href="{{ path('app_login') }}" class="navbar-luxe-link d-none d-lg-inline">Connexion</a>
          <a href="{{ path('app_register') }}" class="btn-gold" style="font-size:.72rem; padding:.6rem 1.4rem;">
            Créer un compte
          </a>
        {% endif %}

        {# Burger mobile #}
        <button class="navbar-toggler-luxe d-lg-none" type="button"
                data-bs-toggle="collapse" data-bs-target="#mobileMenu"
                aria-expanded="false" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    {# Menu mobile #}
    <div class="collapse" id="mobileMenu">
      <ul class="navbar-mobile-nav">
        <li><a href="{{ path('app_home') }}">Accueil</a></li>
        <li><a href="{{ path('app_shop') }}">Boutique</a></li>
        <li><a href="{{ path('app_shop') }}">Collections</a></li>
        <li><a href="#">À propos</a></li>
        <li><a href="#">Contact</a></li>
        {% if app.user %}
          <li><a href="#">Mon compte</a></li>
          {% if is_granted('ROLE_ADMIN') %}
            <li><a href="/admin">Admin</a></li>
          {% endif %}
          <li><a href="{{ path('app_logout') }}" class="text-danger">Se déconnecter</a></li>
        {% else %}
          <li><a href="{{ path('app_login') }}">Connexion</a></li>
          <li><a href="{{ path('app_register') }}">Créer un compte</a></li>
        {% endif %}
      </ul>
    </div>
  </div>
</nav>